# ─── 0G Testnet ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_0G_CHAIN_ID=16602
NEXT_PUBLIC_0G_RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage indexer RPC
OG_INDEXER_RPC=https://indexer-storage-testnet-standard.0g.ai

# Server wallet — fund this with 0G testnet tokens from https://faucet.0g.ai
# NEVER commit this value. Add to .env.local only.
OG_SERVER_PRIVATE_KEY=0x_YOUR_FUNDED_PRIVATE_KEY

# ─── 0G Compute (choose ONE mode) ────────────────────────────────────────────

# OPTION A: Direct API (recommended — no broker SDK, no OOM, simpler)
# Get API key from https://dashboard.0g.ai or 0G Compute docs
OG_COMPUTE_API_URL=https://compute-network-1.integratenetwork.work/v1
OG_COMPUTE_API_KEY=app-sk-YOUR_KEY_HERE

# OPTION B: Broker SDK (legacy — requires provider address + funded ledger)
# OG_COMPUTE_PROVIDER_ADDRESS=0x_PROVIDER_ADDRESS

# Optional: override model (default: qwen/qwen-2.5-7b-instruct)
# Available: deepseek-chat-v3, glm-5, qwen3-vl-30b, gpt-oss-120b
# OG_COMPUTE_MODEL_ID=deepseek-chat-v3

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin secret for lawyer verification API
ADMIN_SECRET=your_admin_secret_here

# ─── WalletConnect (optional — enables mobile wallets via QR) ────────────────
# Get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
